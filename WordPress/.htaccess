RewriteEngine On
RewriteBase /api/

# =====================
# DETAIL
# =====================
RewriteRule ^movie/([0-9]+)/?$ index.php?type=movie&id=$1 [L,QSA]
RewriteRule ^tv/([0-9]+)/?$ index.php?type=tv&id=$1 [L,QSA]

# =====================
# CATEGORY
# =====================
RewriteRule ^category/([0-9]+)/page/([0-9]+)/?$ index.php?category_id=$1&page=$2 [L,QSA]
RewriteRule ^category/([0-9]+)/?$ index.php?category_id=$1 [L,QSA]

# =====================
# PAGE
# =====================
RewriteRule ^page/([0-9]+)/?$ index.php?page=$1 [L,QSA]

# =====================
# ROOT API
# =====================
RewriteRule ^$ index.php [L,QSA]